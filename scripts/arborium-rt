#!/usr/bin/env bash
#
# Forwarding wrapper for the arborium-rt dev CLI. Auto-builds the CLI on
# first run via pnpm, then forwards all args to the built main.js.
#
# Usage (from repo root):
#   ./scripts/arborium-rt <subcommand>          # e.g. bootstrap, build-host, etc.
#   ./scripts/arborium-rt --help                # full subcommand list

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLI_DIR="${REPO_ROOT}/packages/arborium-rt-cli"

if [[ ! -f "${CLI_DIR}/dist/main.js" ]]; then
    echo "==> first-time CLI setup (pnpm install + build)" >&2
    (cd "${REPO_ROOT}" && pnpm install --silent && pnpm --filter @appellation/arborium-rt-cli build --silent)
fi

exec node "${CLI_DIR}/dist/main.js" "$@"
