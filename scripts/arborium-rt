#!/usr/bin/env bash
#
# Forwarding wrapper for the arborium-rt dev CLI. The CLI is a private,
# unpublished workspace package — it's run directly from TypeScript source
# via tsx on every invocation.
#
# Usage (from repo root):
#   ./scripts/arborium-rt <subcommand>          # e.g. bootstrap, build-host, etc.
#   ./scripts/arborium-rt --help                # full subcommand list

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLI_DIR="${REPO_ROOT}/cli"

exec "node" "${CLI_DIR}/src/main.ts" "$@"
