#!/usr/bin/env bash
#
# Release the arborium-rt npm packages to GitHub from a local build.
#
# Packs @discord/arborium-rt (the runtime) and @discord/arborium-rt-plugin-rspack
# (the optional rspack grammar filter), creates (or reuses) a git tag at
# HEAD, pushes it, and attaches both tarballs to a new GitHub Release.
# The tag is driven by the runtime package's version; the plugin must be
# kept in lockstep. Does not publish to npm — run the `pnpm publish` calls
# listed at the bottom separately if you want that.
#
# Usage:
#   scripts/release                # tag = v<runtime package version>
#   scripts/release --tag v1.2.3   # override tag
#   scripts/release --draft        # create the release as a draft
#   scripts/release --dry-run      # stop before tag push + release create
#   scripts/release --skip-build   # reuse artifacts already in dist/ + target/
#   scripts/release --skip-tests   # skip `pnpm -r test`

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${REPO_ROOT}"

TAG=""
DRY_RUN=0
DRAFT=0
SKIP_BUILD=0
SKIP_TESTS=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --tag) TAG="$2"; shift 2 ;;
        --tag=*) TAG="${1#--tag=}"; shift ;;
        --dry-run) DRY_RUN=1; shift ;;
        --draft) DRAFT=1; shift ;;
        --skip-build) SKIP_BUILD=1; shift ;;
        --skip-tests) SKIP_TESTS=1; shift ;;
        -h|--help)
            # Print the header comment block, stripping the leading "# ".
            sed -n '3,/^set -euo/p' "$0" | sed 's/^#\s\?//' | sed '$d'
            exit 0
            ;;
        *)
            echo "error: unknown argument: $1" >&2
            echo "run with --help for usage" >&2
            exit 1
            ;;
    esac
done

step() { echo "==> $*" >&2; }
warn() { echo "warn: $*" >&2; }

# --- required tools -----------------------------------------------------------
missing=()
for cmd in git gh pnpm node cargo emcc tree-sitter; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
done
if [[ ${#missing[@]} -gt 0 ]]; then
    echo "error: missing required tool(s) on PATH: ${missing[*]}" >&2
    echo "       (source emsdk_env.sh if emcc is missing)" >&2
    exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
    echo "error: gh is not authenticated. run: gh auth login" >&2
    exit 1
fi

# --- resolve version + tag ----------------------------------------------------
VERSION="$(node -p "require('./packages/arborium-rt/package.json').version")"
PLUGIN_VERSION="$(node -p "require('./packages/arborium-rt-plugin-rspack/package.json').version")"
if [[ -z "${TAG}" ]]; then
    TAG="v${VERSION}"
fi
step "release tag: ${TAG} (runtime ${VERSION}, plugin ${PLUGIN_VERSION})"
if [[ "${VERSION}" != "${PLUGIN_VERSION}" ]]; then
    warn "runtime (${VERSION}) and plugin (${PLUGIN_VERSION}) versions differ — bumping in lockstep is the convention"
fi

# --- working-tree sanity ------------------------------------------------------
if [[ -n "$(git status --porcelain)" ]]; then
    warn "working tree has uncommitted changes"
fi
CURRENT_BRANCH="$(git branch --show-current)"
if [[ "${CURRENT_BRANCH}" != "main" ]]; then
    warn "not on main (on '${CURRENT_BRANCH}')"
fi

# --- tag conflict -------------------------------------------------------------
CREATE_TAG=1
if git rev-parse --verify -q "refs/tags/${TAG}" >/dev/null; then
    EXISTING="$(git rev-list -n 1 "${TAG}")"
    HEAD_SHA="$(git rev-parse HEAD)"
    if [[ "${EXISTING}" != "${HEAD_SHA}" ]]; then
        echo "error: tag ${TAG} already exists and points to ${EXISTING}" >&2
        echo "       HEAD is ${HEAD_SHA}" >&2
        echo "       either check out that commit or pick a new --tag" >&2
        exit 1
    fi
    step "tag ${TAG} already at HEAD; reusing"
    CREATE_TAG=0
fi

# --- build --------------------------------------------------------------------
if [[ "${SKIP_BUILD}" -eq 0 ]]; then
    step "bootstrap"
    ./scripts/arborium-rt bootstrap

    step "cargo build --release (runtime SIDE_MODULE)"
    cargo build --release

    step "build-host (MAIN_MODULE)"
    ./scripts/arborium-rt build-host

    step "build-all (every grammar in the corpus)"
    ./scripts/arborium-rt build-all

    step "stage-dist"
    ./scripts/arborium-rt stage-dist

    step "pnpm -r build"
    pnpm -r build
else
    step "skipping build (--skip-build)"
fi

# --- test ---------------------------------------------------------------------
if [[ "${SKIP_TESTS}" -eq 0 ]]; then
    step "pnpm -r test"
    pnpm -r test
else
    warn "skipping tests (--skip-tests)"
fi

# --- pack ---------------------------------------------------------------------
TARBALL_DIR="${REPO_ROOT}/target/release-artifacts"
mkdir -p "${TARBALL_DIR}"
# Wipe older tarballs so we don't confuse the version picker below.
rm -f "${TARBALL_DIR}"/discord-arborium-rt-*.tgz \
      "${TARBALL_DIR}"/discord-arborium-rt-plugin-rspack-*.tgz

step "pnpm pack (runtime) -> ${TARBALL_DIR}"
(cd packages/arborium-rt && pnpm pack --pack-destination "${TARBALL_DIR}")

step "pnpm pack (rspack plugin) -> ${TARBALL_DIR}"
(cd packages/arborium-rt-plugin-rspack && pnpm pack --pack-destination "${TARBALL_DIR}")

TARBALL="${TARBALL_DIR}/discord-arborium-rt-${VERSION}.tgz"
PLUGIN_TARBALL="${TARBALL_DIR}/discord-arborium-rt-plugin-rspack-${PLUGIN_VERSION}.tgz"
for t in "${TARBALL}" "${PLUGIN_TARBALL}"; do
    if [[ ! -f "${t}" ]]; then
        echo "error: expected tarball not found: ${t}" >&2
        echo "       contents of ${TARBALL_DIR}:" >&2
        ls -la "${TARBALL_DIR}" >&2
        exit 1
    fi
    step "packed $(basename "${t}") ($(du -h "${t}" | cut -f1))"
done

# --- dry-run stop -------------------------------------------------------------
if [[ "${DRY_RUN}" -eq 1 ]]; then
    step "dry-run: stopping before tag push + release create"
    echo "    runtime tarball: ${TARBALL}"
    echo "    plugin  tarball: ${PLUGIN_TARBALL}"
    exit 0
fi

# --- tag + push ---------------------------------------------------------------
if [[ "${CREATE_TAG}" -eq 1 ]]; then
    step "creating annotated tag ${TAG} at HEAD"
    git tag -a "${TAG}" -m "Release ${TAG}"
fi

step "pushing tag ${TAG}"
git push origin "refs/tags/${TAG}"

# --- github release -----------------------------------------------------------
RELEASE_NOTES="Release ${TAG} (commit $(git rev-parse --short HEAD))"
RELEASE_ARGS=("${TAG}" "${TARBALL}" "${PLUGIN_TARBALL}" --title "${TAG}" --notes "${RELEASE_NOTES}")
if [[ "${DRAFT}" -eq 1 ]]; then
    RELEASE_ARGS+=(--draft)
fi

step "creating GitHub Release ${TAG}"
gh release create "${RELEASE_ARGS[@]}"

step "done: https://github.com/$(gh repo view --json nameWithOwner -q .nameWithOwner)/releases/tag/${TAG}"
step "to publish to npm, run:"
echo "    pnpm --filter @discord/arborium-rt publish"
echo "    pnpm --filter @discord/arborium-rt-plugin-rspack publish"
