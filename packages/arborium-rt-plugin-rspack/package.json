{
  "name": "@discord/arborium-rt-plugin-rspack",
  "version": "0.1.3",
  "description": "Rspack plugin for @discord/arborium-rt. Filters the bundled GRAMMARS map by allow/deny lists so consumers only ship the languages they need.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@discord/arborium-rt": "workspace:*",
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@discord/arborium-rt": "workspace:*",
    "@rspack/core": "^1.0.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
