{
	"name": "@discord/arborium-rt-node",
	"version": "0.1.0",
	"description": "Statically-linked tree-sitter + arborium runtime for Node.js",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/appellation/arborium-rt.git"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"binding.cjs",
		"binding.d.cts"
	],
	"napi": {
		"binaryName": "arborium-rt-node",
		"targets": [
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-unknown-linux-gnu",
			"aarch64-unknown-linux-gnu",
			"x86_64-pc-windows-msvc"
		]
	},
	"scripts": {
		"build": "tsc",
		"pretest": "../../scripts/arborium-rt build node grammars json markdown markdown_inline html css javascript && ../../scripts/arborium-rt build node && tsc",
		"test": "vitest run",
		"test:ci": "tsc && vitest run"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.5"
	},
	"optionalDependencies": {
		"@discord/arborium-rt-node-darwin-x64": "workspace:*",
		"@discord/arborium-rt-node-darwin-arm64": "workspace:*",
		"@discord/arborium-rt-node-linux-x64-gnu": "workspace:*",
		"@discord/arborium-rt-node-linux-arm64-gnu": "workspace:*",
		"@discord/arborium-rt-node-win32-x64-msvc": "workspace:*"
	},
	"engines": {
		"node": ">=22"
	}
}
